---
import { marked } from "marked";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import { blogPosts } from "../../data/blog/posts";
import { getContent, getWordCount, getReadingTime } from "../../data/blog/content";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (() => {
  return blogPosts.map(post => ({
    params: { slug: post.slug },
    props: { post }
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const content = getContent(post.slug);
const wordCount = getWordCount(post.slug);
const readingTime = getReadingTime(post.slug);
const renderedContent = marked.parse(content);
const title = `${post.title} - Ricardo Robles Programador Backend`;
const description = post.description;
---
<Layout title={title} description={description}>
  <Navbar />
  <main class="max-w-3xl mx-auto px-4 py-10">
    <a href="/blog/" class="text-sm text-[#014D85] dark:text-amber-400 hover:underline mb-6 inline-block">
      ← Volver al blog
    </a>
    <article>
      <div class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-4">
        <time datetime={post.date}>{post.date}</time>
        <span>·</span>
        <span>{readingTime}</span>
        <span>·</span>
        <span>{wordCount} palabras</span>
      </div>
      <h1 class="text-4xl mb-6">{post.title}</h1>
      <div class="prose prose-gray dark:prose-invert max-w-none [&_h2]:text-2xl [&_h2]:mt-10 [&_h2]:mb-4 [&_h3]:text-xl [&_h3]:mt-8 [&_h3]:mb-3 [&_p]:mb-4 [&_p]:leading-relaxed [&_code]:bg-gray-200 [&_code]:dark:bg-gray-700 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_pre]:bg-gray-900 [&_pre]:dark:bg-gray-950 [&_pre]:text-gray-100 [&_pre]:p-4 [&_pre]:rounded-xl [&_pre]:overflow-x-auto [&_pre_code]:bg-transparent [&_pre_code]:p-0 [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mb-4 [&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:mb-4 [&_li]:mb-1 [&_strong]:font-semibold [&_a]:text-[#014D85] [&_a]:dark:text-amber-400 [&_a]:hover:underline" set:html={renderedContent} />
      <div class="flex flex-wrap gap-2 mt-8 pt-6 border-t border-gray-300 dark:border-gray-700">
        {post.tags.map(tag => (
          <a
            href={`/blog/?tag=${encodeURIComponent(tag)}`}
            class="px-2 py-1 text-xs rounded bg-[#E6E7C6] dark:bg-gray-700 hover:bg-[#F0BF9B] dark:hover:bg-amber-600 transition-colors"
          >
            {tag}
          </a>
        ))}
      </div>
    </article>
  </main>
</Layout>