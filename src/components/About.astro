---
import ExperienceTimer from "./ExperienceTimer.astro";
---

<div
  id="about"
  class="text-gray-800 mt-14 py-5 md:flex max-w-2xl mx-auto md:space-x-14"
>
  <img
    src="/assets/ricardo.webp"
    alt="Ricardo Robles"
    class="w-[208px] h-[208px] mx-auto rounded-full"
    width="208"
    height="208"
  />
  <div class="max-w-xl">
    <h1 class="text-4xl">¡Hola!, Me llamo Ricardo Robles.</h1>
    <h2 class="text-2xl text-[#014D85]">
      Programador FullStack con fuerte predilección al Backend
    </h2>
    <ExperienceTimer />
    <p>Ingeniero Informático y apasionado por la tecnología.</p>
  </div>
</div>
