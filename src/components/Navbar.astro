---
const routes = [
  { path: "/blog/", label: "Blog" },
  { path: "/#about", label: "Sobre mí" },
  { path: "/#experience", label: "Experiencia" },
  { path: "/#certs", label: "Certificados" },
  { path: "/#projects", label: "Proyectos" },
  { path: "/#tech", label: "Tecnologías" },
  { path: "/#contact", label: "Contáctame" },
];
---

<nav class="flex items-center justify-between min-[790px]:justify-center py-4 fixed top-0 left-0 right-0 z-40 bg-[#E6E7C6] dark:bg-gray-900">
  <button id="menu-toggle" class="hidden max-[790px]:flex flex-col justify-center items-center w-10 h-10 rounded-lg text-[#334155] dark:text-gray-300 hover:bg-[#F0BF9B] dark:hover:bg-amber-600 transition-colors" aria-label="Menú">
    <span id="hamb-line1" class="block w-5 h-0.5 bg-current transition-all duration-300 origin-center"></span>
    <span id="hamb-line2" class="block w-5 h-0.5 bg-current my-1 transition-all duration-300"></span>
    <span id="hamb-line3" class="block w-5 h-0.5 bg-current transition-all duration-300 origin-center"></span>
  </button>

  <div id="backdrop" class="hidden max-[790px]:block fixed inset-0 bg-black/30 z-40 opacity-0 transition-opacity duration-300 pointer-events-none"></div>

  <div id="menu-items" class="max-[790px]:fixed max-[790px]:left-0 max-[790px]:right-0 max-[790px]:top-[60px] max-[790px]:bg-[#E6E7C6] max-[790px]:dark:bg-gray-900 max-[790px]:shadow-xl max-[790px]:rounded-b-2xl max-[790px]:overflow-hidden max-[790px]:max-h-0 max-[790px]:transition-all max-[790px]:duration-300 max-[790px]:ease-in-out flex flex-col min-[790px]:flex-row min-[790px]:items-baseline min-[790px]:space-x-4 items-center z-50">
    {
      routes.map((route) => (
        <a
          href={route.path}
          class="rounded-lg px-3 py-2 text-[#334155] dark:text-gray-300 font-medium hover:bg-[#F0BF9B] dark:hover:bg-amber-600 hover:text-[#0f172a] dark:hover:text-white transition-colors"
        >
          {route.label}
        </a>
      ))
    }
    <button id="theme-toggle-desktop" class="max-[790px]:hidden min-[790px]:flex rounded-lg px-3 py-2 text-[#334155] dark:text-gray-300 font-medium hover:bg-[#F0BF9B] dark:hover:bg-amber-600 hover:text-[#0f172a] dark:hover:text-white transition-colors" aria-label="Cambiar modo oscuro">
      <svg id="sun-icon-desktop" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 hidden dark:inline"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      <svg id="moon-icon-desktop" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 dark:hidden"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
    </button>
  </div>

  <button id="theme-toggle" class="hidden max-[790px]:flex rounded-lg px-3 py-2 text-[#334155] dark:text-gray-300 font-medium hover:bg-[#F0BF9B] dark:hover:bg-amber-600 hover:text-[#0f172a] dark:hover:text-white transition-colors" aria-label="Cambiar modo oscuro">
    <svg id="sun-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 hidden dark:inline"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
    <svg id="moon-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 dark:hidden"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
  </button>
</nav>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("menu-items");
  const backdrop = document.getElementById("backdrop");
  const line1 = document.getElementById("hamb-line1");
  const line2 = document.getElementById("hamb-line2");
  const line3 = document.getElementById("hamb-line3");

  let open = false;

  function openMenu() {
    open = true;
    menu?.classList.remove("max-[790px]:max-h-0");
    menu?.classList.add("max-[790px]:max-h-96", "max-[790px]:pb-4");
    backdrop?.classList.remove("opacity-0", "pointer-events-none");
    backdrop?.classList.add("opacity-100");
    line1?.classList.add("rotate-45", "translate-y-[6px]");
    line2?.classList.add("opacity-0", "scale-0");
    line3?.classList.add("-rotate-45", "-translate-y-[6px]");
  }

  function closeMenu() {
    open = false;
    menu?.classList.remove("max-[790px]:max-h-96", "max-[790px]:pb-4");
    menu?.classList.add("max-[790px]:max-h-0");
    backdrop?.classList.remove("opacity-100");
    backdrop?.classList.add("opacity-0", "pointer-events-none");
    line1?.classList.remove("rotate-45", "translate-y-[6px]");
    line2?.classList.remove("opacity-0", "scale-0");
    line3?.classList.remove("-rotate-45", "-translate-y-[6px]");
  }

  toggle?.addEventListener("click", () => {
    if (open) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  document.addEventListener("click", (e) => {
    if (!e.target.closest("nav") && open) {
      closeMenu();
    }
  });

  document.querySelectorAll("#menu-items a").forEach(a => {
    a.addEventListener("click", closeMenu);
  });

  function handleThemeToggle() {
    const html = document.documentElement;
    const isDark = html.classList.toggle("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
    document.documentElement.style.backgroundColor = isDark ? "#111827" : "#E6E7C6";
  }

  document.getElementById("theme-toggle")?.addEventListener("click", handleThemeToggle);
  document.getElementById("theme-toggle-desktop")?.addEventListener("click", handleThemeToggle);
</script>