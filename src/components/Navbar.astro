---
const routes = [
  { path: "#about", label: "Sobre mí" },
  { path: "#experience", label: "Experiencia" },
  { path: "#certs", label: "Certificados" },
  { path: "#projects", label: "Proyectos" },
  { path: "#tech", label: "Tecnologías" },
  { path: "#contact", label: "Contáctame" },
];
---

<nav class="flex sm:justify-center items-center flex-col sm:flex-row sm:items-baseline sm:space-x-4">
  {
    routes.map((route) => (
      <a
        href={route.path}
        class="rounded-lg px-3 py-2 text-[#334155] font-medium hover:bg-[#F0BF9B] hover:text-[#0f172a] border-[#F0BF9A] border-b-1"
      >
        {route.label}
      </a>
    ))
  }
</nav>
