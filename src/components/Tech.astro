---
import { techs } from "../data/techs";
---

<section id="tech" class="text-center fade-in">
  <h2 class="text-2xl mt-10">Tecnologías con las que me siento cómodo trabajando</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-10 max-w-5xl mx-auto px-4">
    {techs.map((tech) => (
      <article class="text-center shadow-lg p-10 rounded-xl bg-[#F5F0E0] dark:bg-gray-800">
        <div class="max-w-xl mx-auto">
          <img src={tech.imgPath} alt={tech.title} class="mx-auto" height="80" width="80" />
          <h3 class="text-lg font-medium pt-6 pb-2 mx-auto text-center">{tech.title}</h3>
        </div>
        <p class="py-2">{tech.subtitle}</p>
      </article>
    ))}
  </div>
</section>
