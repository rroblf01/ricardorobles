---
import { techs } from "../data/techs";
---

<section id="tech" class="text-center fade-in">
  <h3 class="text-2xl mt-10">Tecnologías con las que me siento cómodo trabajando</h3>
  <div class="lg:flex flex-wrap justify-center mt-10">
    {techs.map((tech) => (
      <div class="text-center shadow-lg p-10 ml-2 rounded-xl lg:max-w-xs bg-white dark:bg-gray-800">
        <div class="md:flex max-w-xl mx-auto justify-center md:space-x-4">
          <img src={tech.imgPath} alt={tech.title} class="mx-auto" height="80" width="80" />
          <h3 class="text-lg font-medium pt-8 pb-2 left-10 mx-auto">{tech.title}</h3>
        </div>
        <p class="py-2">{tech.subtitle}</p>
        <div class="mt-4">
          <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2.5">
            <div class="bg-[#014D85] dark:bg-amber-500 h-2.5 rounded-full" style={`width: ${tech.level}%`}></div>
          </div>
          <span class="text-xs text-gray-500 dark:text-gray-400 mt-1 block">{tech.levelLabel}</span>
        </div>
      </div>
    ))}
  </div>
</section>
