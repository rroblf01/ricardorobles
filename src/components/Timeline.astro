---
export interface Props {
  title: string;
  elements: { title: string; subtitle: string }[];
}
const { title, elements } = Astro.props;
---

<div class="flex flex-col items-center">
  <p class="text-lg">{title}</p>
  <div class="relative max-w-2xl">
  <div class="absolute top-0 h-full border-r-2 border-gray-500 left-3"></div>
  <ul class="space-y-10">
    <li>
      <div class="flex items-center">
        <span class="w-6 h-6 bg-gray-500 rounded-full"></span>
        <h3 class="ml-4 font-bold text-gray-600">Actualidad</h3>
      </div>
      <div class="ml-12">
        <p class="text-sm text-[#4A4A4A] min-h-0"> </p>
      </div>
    </li>
    {elements.map((el) => (
      <li>
        <div class="flex items-center">
          <span class="w-6 h-6 bg-gray-500 rounded-full"></span>
          <h3 class="ml-4 font-bold text-gray-600">{el.title}</h3>
        </div>
        <div class="ml-12">
          <p class="text-sm text-[#4A4A4A] min-h-0">{el.subtitle}</p>
        </div>
      </li>
    ))}
  </ul>
</div>
</div>
