---
import { getWordCount, getReadingTime } from "../data/blog/content";

export interface PostMeta {
  slug: string;
  title: string;
  date: string;
  description: string;
  tags: string[];
}

export interface Props {
  posts: PostMeta[];
  allTags: string[];
  currentPage: number;
  totalPages: number;
}

const { posts, allTags, currentPage, totalPages } = Astro.props;
---

<div class="mb-6 flex flex-col sm:flex-row gap-4">
  <div class="flex-1">
    <label for="q" class="sr-only">Buscar artículos</label>
    <input
      id="q"
      type="search"
      placeholder="Buscar por título..."
      class="w-full px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-800 dark:text-gray-200"
    />
  </div>
</div>

<div id="tags-filter" class="flex flex-wrap gap-2 mb-6">
  {allTags.map(tag => (
    <button
      data-tag={tag}
      class="tag-filter-btn px-3 py-1 text-sm rounded cursor-pointer transition-colors"
    >
      {tag}
    </button>
  ))}
  <button id="toggle-tags-btn" class="px-2 py-1 text-xs rounded border border-gray-300 dark:border-gray-500 text-gray-500 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors cursor-pointer" title="Ocultar tags">▼</button>
</div>

<div id="posts-grid" class="grid gap-6">
  {posts.map(post => {
    const wordCount = getWordCount(post.slug);
    const readingTime = getReadingTime(post.slug);
    return (
      <article
        data-slug={post.slug}
        data-title={post.title.toLowerCase()}
        data-tags={post.tags.join(",")}
        class="post-card p-6 rounded-xl bg-[#F5F0E0] dark:bg-gray-800 shadow-md"
      >
        <div class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-2">
          <time datetime={post.date}>{post.date}</time>
          <span>·</span>
          <span>{readingTime}</span>
          <span>·</span>
          <span>{wordCount} palabras</span>
        </div>
        <h2 class="text-2xl font-semibold mb-2">
          <a href={`/blog/${post.slug}/`} class="hover:text-[#014D85] dark:hover:text-amber-400 transition-colors">
            {post.title}
          </a>
        </h2>
        <p class="text-gray-600 dark:text-gray-300 mb-4">{post.description}</p>
        <div class="flex flex-wrap gap-2">
          {post.tags.map(tag => (
            <button data-tag-btn={tag} class="px-2 py-1 text-xs rounded bg-[#E6E7C6] dark:bg-gray-700 hover:bg-[#F0BF9B] dark:hover:bg-amber-600 transition-colors cursor-pointer">{tag}</button>
          ))}
        </div>
      </article>
    );
  })}
</div>

<nav id="pagination" class="flex justify-center items-center gap-4 mt-10" aria-label="Paginación">
  {currentPage > 1 ? (
    <a href={currentPage === 2 ? "/blog/" : `/blog/page/${currentPage - 1}/`} class="px-4 py-2 rounded-lg bg-[#F5F0E0] dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-[#F0BF9B] dark:hover:bg-amber-600 transition-colors">
      ← Anterior
    </a>
  ) : (
    <span class="px-4 py-2 rounded-lg bg-gray-200 dark:bg-gray-700 text-gray-400 cursor-not-allowed">← Anterior</span>
  )}
  <span class="text-sm text-gray-600 dark:text-gray-400">
    Página {currentPage} de {totalPages}
  </span>
  {currentPage < totalPages ? (
    <a href={`/blog/page/${currentPage + 1}/`} class="px-4 py-2 rounded-lg bg-[#F5F0E0] dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-[#F0BF9B] dark:hover:bg-amber-600 transition-colors">
      Siguiente →
    </a>
  ) : (
    <span class="px-4 py-2 rounded-lg bg-gray-200 dark:bg-gray-700 text-gray-400 cursor-not-allowed">Siguiente →</span>
  )}
</nav>

<style>
  .tag-filter-btn {
    background-color: #E6E7C6;
    color: #374151;
    border: 1px solid transparent;
  }
  .tag-filter-btn:hover {
    background-color: #F0BF9B;
  }
  .tag-filter-btn[data-active="true"] {
    background-color: #014D85;
    color: white;
  }
  .tag-filter-btn[data-active="true"]:hover {
    background-color: #013a66;
  }
  html.dark .tag-filter-btn {
    background-color: #374151;
    color: #D1D5DB;
  }
  html.dark .tag-filter-btn[data-active="true"] {
    background-color: #014D85;
    color: white;
  }
  #tags-filter[data-tags-hidden="true"] .tag-filter-btn {
    display: none;
  }
</style>

<style is:global>
  [data-tag-btn].tag-highlighted {
    background-color: #014D85 !important;
    color: white !important;
  }
  [data-tag-btn].tag-highlighted:hover {
    background-color: #013a66 !important;
  }
  html.dark [data-tag-btn].tag-highlighted {
    background-color: #014D85 !important;
    color: white !important;
  }
  html.dark [data-tag-btn].tag-highlighted:hover {
    background-color: #013a66 !important;
  }
</style>


