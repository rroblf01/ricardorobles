<div id="timer" class="text-2xl underline">
  Con 0 años, 0 meses, 0 días, 0 horas, 0 minutos, 0 segundos de experiencia.
</div>

<script>
  function calculateTime() {
    const start = new Date("2020-02-01");
    const now = new Date();
    const diffSec = (now.getTime() - start.getTime()) / 1000;

    const years = Math.floor(diffSec / (365.25 * 86400));
    const months = Math.floor((diffSec % (365.25 * 86400)) / (30.44 * 86400));
    const days = Math.floor((diffSec % (30.44 * 86400)) / 86400);
    const hours = Math.floor((diffSec % 86400) / 3600);
    const minutes = Math.floor((diffSec % 3600) / 60);
    const seconds = Math.floor(diffSec % 60);

    document.getElementById("timer").innerHTML =
      `Con ${years} años, ${months} meses, ${days} días, ${hours} horas, ${minutes} minutos, ${seconds} segundos de experiencia.`;
  }

  calculateTime();
  setInterval(calculateTime, 1000);
</script>
