---
import { projects } from "../data/projects";
---

<section id="projects" class="text-center fade-in">
  <h2 class="text-2xl mt-10">Proyectos que he desarrollado ultimamente</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-10 max-w-screen-2xl mx-auto px-4">
    {projects.map((project, i) => (
      <article class="relative flex flex-row rounded-xl bg-clip-border text-gray-700 dark:text-gray-200 shadow-md min-h-[300px] h-full bg-[#F5F0E0] dark:bg-gray-800">
          <div class="relative m-0 w-2/5 shrink-0 rounded-xl rounded-r-none bg-[#EDE8D8] dark:bg-gray-700 bg-clip-border text-gray-700">
            <a href={project.url} target="_blank" rel="noopener noreferrer" class="block h-full w-full">
              <img
                src={project.imgPath}
                alt={`Proyecto ${project.title} - ${project.description}`}
                class="object-cover object-center h-full w-full rounded-xl"
                width="309"
                height="205"
                aspect-ratio="309/205"
                fetchpriority={i === 0 ? "high" : undefined}
                loading={i === 0 ? "eager" : "lazy"}
                decoding={i === 0 ? "sync" : "async"}
              />
            </a>
          </div>
          <div class="p-6 flex flex-col text-left">
            <h4 class="mb-4 block font-sans text-base font-semibold uppercase leading-relaxed tracking-normal text-[#8F0F37] dark:text-amber-400 antialiased">
              <a href={project.url} target="_blank">{project.title}</a>
            </h4>
            <p class="mb-2 block font-sans text-base font-normal leading-relaxed text-gray-700 dark:text-gray-300 antialiased flex-grow">
              {project.description}
            </p>
            <a href={project.url} target="_blank" class="text-[#4A4A4A] dark:text-gray-400 underline" rel="noopener noreferrer">
              Ver proyecto
            </a>
            <div class="text-xs mt-2 space-y-1">
              {project.sources.map((source) => (
                <div>
                  <a href={source.url} target="_blank" rel="noopener noreferrer" class="text-[#8F0F37] dark:text-amber-400 underline font-medium">
                    {source.text}
                  </a>
                  <span class="text-gray-500 dark:text-gray-400 ml-2 break-all">{source.url}</span>
                </div>
              ))}
            </div>
            <div class="text-xs mt-3 flex items-center flex-wrap gap-1.5">
              {project.techs.map((tech) => (
                <span class="inline-flex items-center justify-center w-[30px] h-[30px]">
                  <img src={tech.path} alt={tech.name} title={tech.name} class="max-w-full max-h-full" />
                </span>
              ))}
            </div>
          </div>
        </article>
    ))}
  </div>
</section>
