---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Ricardo Robles — Programador Backend | Python, Django & TypeScript",
  description = "Portafolio de Ricardo Robles. Programador backend con 6+ años de experiencia en Python, Django, Docker y TypeScript.",
  ogImage = "https://ricardorobles.es/assets/meta-portafolios.jpg",
} = Astro.props;

const url = new URL(Astro.url.pathname, "https://ricardorobles.es");
---

<!doctype html>
<html lang="es" style="background-color: #E6E7C6;">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style>
      html { background-color: #E6E7C6; }
      html.dark { background-color: #111827; }
    </style>
    <script is:inline>
      (function() {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const isDark = stored === "dark" || (!stored && prefersDark);
        if (isDark) {
          document.documentElement.classList.add("dark");
          document.documentElement.style.backgroundColor = "#111827";
        }
      })();
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Ricardo Robles Fernández" />
    <meta name="theme-color" content="#E6E7C6" />
    <link rel="canonical" href={url.href} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={url.href} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json">
      [{
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Ricardo Robles",
        "jobTitle": "Programador Backend",
        "url": "https://ricardorobles.es",
        "sameAs": [
          "https://linkedin.com/in/ricardoroblesfernandez/",
          "https://github.com/rroblf01"
        ],
        "knowsAbout": ["Python", "Django", "FastAPI", "Docker", "PostgreSQL", "TypeScript", "JavaScript", "Git"],
        "description": "Programador Backend con 6+ años de experiencia en Python, Django, Docker y TypeScript. Ingeniero Informático apasionado por la tecnología."
      },
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Ricardo Robles — Programador Backend",
        "url": "https://ricardorobles.es"
      }]
    </script>

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://region1.google-analytics.com" />
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="preload" href="/assets/ricardo.webp" as="image" />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-31TBY36R16"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-31TBY36R16');
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
