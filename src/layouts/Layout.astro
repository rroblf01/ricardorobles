            }
          },
          {
            "@type": "Question",
            "name": "¿Cómo puedo contactar con Ricardo Robles?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Puedes contactar con Ricardo Robles a través de su correo electrónico ricardo.r.f@hotmail.com o mediante su perfil de LinkedIn."
            }
          }
        ]
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        "name": "Ricardo Robles - Programador Backend",
        "description": "Servicios de desarrollo backend especializado en Python, Django, FastAPI y TypeScript. Más de 6 años de experiencia.",
        "url": "https://ricardorobles.es",
        "telephone": "+34-ricardo-r-f",
        "email": "ricardo.r.f@hotmail.com",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "León",
          "addressRegion": "Castilla y León",
          "addressCountry": "ES"
        },
        "areaServed": ["León", "España", "Remoto"],
        "serviceType": ["Desarrollo Backend", "API REST", "Bases de datos", "DevOps"],
        "priceRange": "$$",
        "image": "https://ricardorobles.es/assets/meta-portafolios.jpg",
        "sameAs": [
          "https://linkedin.com/in/ricardoroblesfernandez/",
          "https://github.com/rroblf01"
        ]
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Inicio",
            "item": "https://ricardorobles.es"
          }
        ]
      }
